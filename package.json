{
  "name": "@gaberagland/remote-control",
  "version": "0.1.0",
  "description": "Install the Remote Control Codex skill for continuing Codex threads from iMessage.",
  "type": "module",
  "bin": {
    "remote-control": "./bin/remote-control.mjs"
  },
  "files": [
    "bin/",
    "remote-control/"
  ],
  "packageManager": "pnpm@10.26.0",
  "scripts": {
    "build": "pnpm --filter @gaberagland/remote-control-relay build",
